# Mode the application runs in. Allowed values: locale, production
MODE=locale

# Django secret key used for cryptographic signing.
# Ensure to use a strong random value in production.
SECRET_KEY=

# Public URL of your application that is accessible from the outside
SELF_URL=https://yourdomain.com

# Telegram Login credentials
# https://core.telegram.org/bots/telegram-login#tldr
TELEGRAM_LOGIN_CLIENT_ID=
TELEGRAM_LOGIN_CLIENT_SECRET=

# Database configuration
DATABASE_NAME=constructor_telegram_bots
DATABASE_USER=exg1o
DATABASE_PASSWORD=password

# Docker socket path
DOCKER_SOCKET=/var/run/docker.sock

# Public HTTP port exposed by Nginx on the host machine
HTTP_PORT=8000
